---
import TitleSection from "../components/titleSection.astro";
import Section from "../components/section.astro";
import SkillCard from "../components/SkillCard.astro";
import { skillCategories } from "../data/portfolio.js";
---

<Section id="skills" extraClass="my-8 sm:my-10 md:my-16">
    <TitleSection imageSrc="/icons/portfolio_icon.svg" title="Habilidades" i18nKey="skillsTitle" />

    <div class="flex flex-col gap-6 sm:gap-8 mt-4 sm:mt-6">
        {
            skillCategories.map((category) => (
                <div class="flex flex-col gap-5 sm:gap-6 bg-white/5 border border-white/5 p-5 sm:p-7 rounded-[2rem] shadow-sm backdrop-blur-sm transition-colors duration-300 hover:bg-white/10 hover:border-white/10 group">
                    <div class="flex items-center gap-4">
                        <h3 class="text-xl sm:text-2xl font-black text-title whitespace-nowrap" data-i18n={category.i18nTitle}>
                            {category.title}
                        </h3>
                        <div class="h-[2px] w-full bg-gradient-to-r from-accent/50 to-transparent rounded-full opacity-50 group-hover:opacity-100 transition-opacity duration-300" />
                    </div>
                    <div class="flex flex-wrap gap-4 sm:gap-6 justify-start">
                        {category.skills.map((skill) => (
                            <SkillCard name={skill.name} icon={skill.icon} i18nExperienceKey={skill.i18nExp} />
                        ))}
                    </div>
                </div>
            ))
        }
    </div>
</Section>
