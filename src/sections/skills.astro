---
import SectionWithTitle from "../components/SectionWithTitle.astro";
import SkillCategoryPanel from "../components/SkillCategoryPanel.astro";
import { skillCategories } from "../data/index.js";
---

<SectionWithTitle id="skills" extraClass="my-8 sm:my-10 md:my-16" imageSrc="/icons/portfolio_icon.svg" title="Habilidades" i18nKey="skillsTitle">
    <div class="flex flex-col gap-6 sm:gap-8 mt-4 sm:mt-6">
        {
            skillCategories.map((category) => <SkillCategoryPanel category={category} />)
        }
    </div>
</SectionWithTitle>
