---
import SectionWithTitle from "../components/SectionWithTitle.astro";
import Project from "../components/project.astro";
import { projects } from "../data/index.js";
import Tekkure_demo from "../assets/demos/tekkure_demo.jpg";
import Densora_demo from "../assets/demos/densora_demo.png";
const images: Record<string, any> = {
    "../assets/demos/tekkure_demo.jpg": Tekkure_demo,
    "../assets/demos/densora_demo.png": Densora_demo,
};
---
<SectionWithTitle id="projects" imageSrc="/icons/code_icon.svg" title="Proyectos" i18nKey="projectsTitle">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full">
        {projects.map((project) => <Project {...project} image={images[project.imagePath]} />)}
    </div>
</SectionWithTitle>
