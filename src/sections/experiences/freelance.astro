---
import Text from "../../components/text.astro";
import { experiences } from "../../data/portfolio.js";
const data = experiences[0];
---

<div class="relative pl-8 pb-12 last:pb-0 group">
    <!-- Dot -->
    <div class="absolute -left-[10px] top-1 w-4 h-4 rounded-full bg-accent border-4 border-bg-dark z-10 transition-transform duration-300 group-hover:scale-125 shadow-[0_0_10px_rgba(24,205,169,0.5)]"></div>

    <div class="glass-card p-6 space-y-3 hover:translate-x-2 transition-all duration-300">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
                <span class="text-accent font-black text-xs tracking-widest uppercase mb-1 block">{data.year}</span>
                <Text as="h3" type="subTitle" extraClass="!text-xl" i18nKey={data.titleKey} text={data.title} />
            </div>
            <span class="px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-[10px] font-bold text-accent uppercase tracking-wider" i18nKey={data.subtitleKey}>{data.subtitle}</span>
        </div>
        <Text type="mini" extraClass="opacity-80 leading-relaxed" i18nKey={data.descriptionKey} text={data.description} />
    </div>
</div>
