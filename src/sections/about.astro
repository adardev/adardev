---
import Section from "../components/section.astro";
import TitleSection from "../components/titleSection.astro";
import Text from "../components/text.astro";
---

<Section id="about" extraClass="my-12 sm:my-16 md:my-24">
    <TitleSection imageSrc="/icons/user_icon.svg" title="Sobre Mí" i18nKey="aboutTitle" />
    <Text
        as="p"
        type="text"
        extraClass="leading-relaxed sm:text-lg opacity-90"
        i18nKey="aboutText"
        text="Desarrollador enfocado en crear soluciones digitales eficientes y en la optimización de los sistemas que las soportan. Mi perfil combina la construcción de software con un conocimiento sólido en arquitectura de hardware y mantenimiento técnico, asegurando siempre el mejor rendimiento de los equipos y aplicaciones. Cuento con un nivel de inglés técnico intermedio, ideal para el análisis de documentación y la resolución de problemas."
    />
</Section>
