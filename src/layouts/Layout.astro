---
import { ClientRouter } from "astro:transitions";
import NavBar from "../components/NavBar.astro";
import Text from "../components/text.astro";
import "../styles/global.css";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/logos/adardev_logo.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title || "adardev | Portfolio"}</title>
        <meta name="description" content={description || "Portfolio de adardev - Desarrollador Web y Movil"} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet" />

        <ClientRouter />
    </head>

    <body class="bg-bg-dark text-body font-sans selection:bg-accent/30 selection:text-accent overflow-x-hidden antialiased">
        <NavBar />

        <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
            <slot />
        </main>

        <footer class="py-10 text-center opacity-50 text-sm">
            <Text as="p" type="mini" text={`&copy; ${new Date().getFullYear()} adardev. Casi todos los derechos reservados.`} />
        </footer>

        <script>
            import { initI18n } from "../scripts/i18n.js";
            initI18n();
        </script>
    </body>
</html>

<style is:global>
    :root {
        color-scheme: dark;
    }
    html {
        scroll-behavior: smooth;
    }
    body {
        min-height: 100vh;
    }
</style>
