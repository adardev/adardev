---
import { ClientRouter } from "astro:transitions";
import NavBar from "../components/NavBar.astro";
import "../styles/global.css";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" href="/logos/adardev_logo.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title || "Brandon López | Portfolio"}</title>
        <meta name="description" content={description || "Portfolio de Brandon López - Desarrollador Web y Movil"} />

        <ClientRouter />
    </head>

    <body class="bg-bg-dark text-body font-sans selection:bg-accent/30 selection:text-accent overflow-x-hidden antialiased">
        <NavBar />

        <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
            <slot />
        </main>

        <script>
            import { initI18n } from "../scripts/i18n.js";
            import { initUI } from "../scripts/ui.js";
            initI18n();
            initUI();
            document.addEventListener("astro:page-load", initUI);
        </script>
    </body>
</html>

<style is:global>
    :root {
        color-scheme: dark;
    }
    html {
        scroll-behavior: smooth;
    }
    body {
        min-height: 100vh;
    }
</style>
