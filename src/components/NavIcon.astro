---
const { icon } = Astro.props;
const icons: Record<string, { paths: string[]; polylines?: string[]; circles?: string[]; rects?: { attrs: Record<string, string> }[] }> = {
    home: { paths: ["m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"], polylines: ["9 22 9 12 15 12 15 22"] },
    user: { paths: ["M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"], circles: ["12 7 4"] },
    briefcase: { rects: [{ attrs: { width: "20", height: "14", x: "2", y: "7", rx: "2", ry: "2" } }], paths: ["M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"] },
    code: { polylines: ["16 18 22 12 16 6", "8 6 2 12 8 18"], paths: [] },
    cpu: { rects: [{ attrs: { x: "4", y: "4", width: "16", height: "16", rx: "2" } }, { attrs: { x: "9", y: "9", width: "6", height: "6" } }], paths: ["M9 1V4", "M15 1V4", "M9 20V23", "M15 20V23", "M20 9H23", "M20 14H23", "M1 9H4", "M1 14H4"] },
};
const iconData = icons[icon];
---

{
    iconData && (
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-6 sm:h-6">
            {iconData.paths?.map((d) => (
                <path d={d} />
            ))}
            {iconData.polylines?.map((pts) => (
                <polyline points={pts} />
            ))}
            {iconData.circles?.map((c) => {
                const [cx, cy, r] = c.split(" ");
                return <circle cx={cx} cy={cy} r={r} />;
            })}
            {iconData.rects?.map((rect) => (
                <rect {...rect.attrs} />
            ))}
        </svg>
    )
}
