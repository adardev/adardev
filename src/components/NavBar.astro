---
import { Image } from "astro:assets";
import adardev_logo from "../assets/logos/adardev_logo.svg";
import NavIcon from "./NavIcon.astro";

const navLinks = [
    { name: "Inicio", i18n: "navHome", href: "/", icon: "home" },
    { name: "Sobre Mi", i18n: "navAbout", href: "#about", icon: "user" },
    { name: "Experiencia", i18n: "navExperience", href: "#experience", icon: "briefcase" },
    { name: "Proyectos", i18n: "navProjects", href: "#projects", icon: "code" },
    { name: "Habilidades", i18n: "navSkills", href: "#skills", icon: "cpu" },
];
---

<!-- Navbar Left: Logo & Brand -->
<div class="fixed top-4 left-4 sm:left-6 md:left-8 z-[100] glass-nav rounded-2xl">
    <a href="/" class="p-2 sm:p-2.5 flex items-center gap-2 group cursor-pointer transition-all duration-300" aria-label="Inicio">
        <Image src={adardev_logo} alt="adardev Logo" class="w-7 h-7 sm:w-8 sm:h-8 transition-transform group-hover:scale-110" />
        <span class="font-bold text-lg hidden sm:block tracking-tight text-body">adardev</span>
    </a>
</div>

<!-- Navbar Center: Navigation Links -->
<header class="fixed top-4 left-0 w-full z-[90] pointer-events-none flex justify-center px-4">
    <nav id="navbar-container" class="glass-nav rounded-2xl flex items-center gap-1 sm:gap-2 px-3 py-1.5 sm:px-4 sm:py-2 pointer-events-auto transition-all duration-500 shadow-2xl">
        {
            navLinks.map((link) => (
                <a href={link.href} class="nav-item group relative p-2.5 sm:p-3 rounded-xl transition-all duration-300 hover:bg-white/5" aria-label={link.name}>
                    <span class="sr-only" data-i18n={link.i18n}>
                        {link.name}
                    </span>
                    <NavIcon icon={link.icon} />

                    {/* Tooltip for desktop */}
                    <span class="absolute -bottom-12 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-bg-card border border-white/10 text-body text-[11px] font-bold rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 whitespace-nowrap pointer-events-none hidden md:block shadow-xl z-[110]" data-i18n={link.i18n}>
                        {link.name}
                    </span>
                </a>
            ))
        }
    </nav>
</header>

<!-- Navbar Right: Actions (Theme, Lang) -->
<div class="fixed top-4 right-4 sm:right-6 md:right-8 z-[100] flex gap-2">
    <div class="glass-nav rounded-2xl flex items-center gap-1 p-1">
        <button id="theme-toggle" class="nav-item p-2 sm:p-2.5 rounded-xl cursor-pointer hover:bg-white/5 transition-colors" aria-label="Cambiar tema">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-6 sm:h-6 sun-icon hidden dark:block"
                ><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg
            >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-6 sm:h-6 moon-icon block dark:hidden"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
        </button>

        <button id="language-toggle" class="nav-item p-2 sm:p-2.5 rounded-xl cursor-pointer hover:bg-white/5 transition-colors flex items-center justify-center font-bold text-xs sm:text-sm text-accent w-10 h-10 sm:w-11 sm:h-11 border-l border-white/5 ml-1" aria-label="Cambiar idioma"> ES </button>
    </div>
</div>

<script>
    import { initNav } from "../scripts/nav.js";
    document.addEventListener("astro:page-load", initNav);
</script>

<style>
    /* Active Link Indicator logic moved to nav.js and global.css */
    #navbar-container {
        border: 1px solid rgba(255, 255, 255, 0.08);
    }
</style>
