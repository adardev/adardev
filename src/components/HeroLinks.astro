---
import ButtonToolTip from "./buttonToolTip.astro";
import { socialLinks } from "../data/index.js";

const heroLinkCompactClass = "w-12 h-12 px-0 justify-center rounded-2xl sm:w-auto sm:h-12 sm:px-3 sm:justify-start";
---

<div id="hero-links" class="hero-links group w-full sm:w-fit relative z-10">
    <div class="hero-links-list flex flex-wrap justify-center gap-2 w-full sm:w-auto sm:flex-nowrap sm:justify-start">
        {socialLinks.map((social) => <ButtonToolTip {...social} extraClass={heroLinkCompactClass} />)}
        <ButtonToolTip iconSrc="/icons/cv_icon.svg" label="Ver curriculum Vitae" link="/cvs/adardevCV.pdf" i18nKey="heroCV" extraClass={heroLinkCompactClass} />
    </div>
</div>
