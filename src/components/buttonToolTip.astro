---
const { iconSrc, label, link, i18nKey } = Astro.props;
import Text from "./text.astro";
import Tooltip from "./Tooltip.astro";
---

<a href={link} class="relative group flex items-center glass-card hover:bg-accent/10 h-12 px-3 transition-all duration-500 rounded-2xl overflow-hidden hover:pr-5 group/btn" aria-label={label} data-i18n-aria-label={i18nKey} target="_blank" rel="noopener noreferrer">
    <div class="w-6 h-6 flex-shrink-0 transition-colors duration-300 text-body group-hover:text-accent" style={`-webkit-mask-image: url(${iconSrc}); mask-image: url(${iconSrc}); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; background-color: currentColor;`} aria-hidden="true"></div>
    <div class="max-w-0 overflow-hidden group-hover:max-w-xs transition-all duration-500 ease-in-out opacity-0 group-hover:opacity-100 ml-0 group-hover:ml-3 flex items-center">
        <Text type="badge" text={label} i18nKey={i18nKey} extraClass="!text-accent !font-black whitespace-nowrap !text-[15px] tracking-wider" />
    </div>
</a>
