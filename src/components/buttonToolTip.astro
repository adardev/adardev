---
const { iconSrc, label, link, i18nKey, extraClass = "" } = Astro.props;
import Text from "./text.astro";
import IconMask from "./IconMask.astro";
---
<a href={link} class={`social-link-btn relative group/btn flex items-center glass-card h-12 px-3 rounded-2xl overflow-hidden transition-[width,padding,border-radius,background-color,transform] duration-300 ease-out sm:hover:bg-accent/10 sm:hover:pr-5 ${extraClass}`} aria-label={label} data-i18n-aria-label={i18nKey} target="_blank" rel="noopener noreferrer">
    <IconMask src={iconSrc} extraClass="w-6 h-6 flex-shrink-0 transition-colors duration-300 text-body" />
    <div class="social-link-label max-w-0 overflow-hidden opacity-0 ml-0 flex items-center min-w-0 transition-[max-width,opacity,margin] duration-300 ease-out max-sm:group-[.is-center]:max-w-full max-sm:group-[.is-center]:opacity-100 max-sm:group-[.is-center]:ml-2 sm:group-hover/btn:max-w-xs sm:group-hover/btn:opacity-100 sm:group-hover/btn:ml-3">
        <Text type="badge" text={label} i18nKey={i18nKey} extraClass="!text-body !font-bold whitespace-nowrap !text-[12px] sm:!text-[15px] tracking-wide" />
    </div>
</a>