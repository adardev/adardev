---
const { src, extraClass = "" } = Astro.props;
---

<div class={extraClass} style={`-webkit-mask-image: url(${src}); mask-image: url(${src}); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; background-color: currentColor;`} aria-hidden="true"></div>
