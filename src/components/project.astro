---
import { Image } from "astro:assets";
import Text from "./text.astro";
const { title, description, image, logo, tech = [], github, live, platform, titleKey, descKey } = Astro.props;
---
<div class="group card-base overflow-hidden hover:-translate-y-1 h-full flex flex-col">
    <div class="w-full relative overflow-hidden bg-accent/5 aspect-video shrink-0">
        <Image src={image} alt={title} class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-250"></div>
    </div>
    <div class="w-full p-4 sm:p-5 flex flex-col flex-1 justify-between gap-4">
        <div class="space-y-3">
            <div class="flex items-center justify-between gap-3 flex-wrap">
                <div class="flex items-center gap-2.5">
                    {logo && <img src={logo} width="28" height="28" class="" alt="" />}
                    <Text as="h3" type="subTitle" extraClass="!text-lg sm:!text-xl tracking-tight" i18nKey={titleKey} text={title} />
                </div>
                {
                    (platform || tech.length > 0) && (
                        <div class="flex items-center gap-2 bg-accent/10 px-2 py-0.5 rounded-full">
                            {platform && <img src={platform} width="14" height="14" class="" alt="" />}
                            {platform && tech.length > 0 && <div class="w-[1px] h-2.5 bg-accent/30 mx-0.5" />}
                            {tech.length > 0 && (
                                <div class="flex gap-1">
                                    {tech.map((icon: string) => (
                                        <img src={icon} width="14" height="14" class="" alt="" />
                                    ))}
                                </div>
                            )}
                        </div>
                    )
                }
            </div>
            <Text type="mini" extraClass="leading-relaxed line-clamp-2" i18nKey={descKey} text={description} />
        </div>
        <div class="flex items-center gap-2 mt-auto">
            {
                github && (
                    <a href={github} target="_blank" rel="noopener noreferrer" class="flex-1 btn-base bg-bg-card-hover px-3 py-2 group/btn text-body transition-colors duration-300 gap-2 font-medium">
                        <div class="w-4 h-4" style={`-webkit-mask-image: url('/logos/github_logo.svg'); mask-image: url('/logos/github_logo.svg'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center; background-color: currentColor;`} aria-hidden="true" />
                        <Text as="span" type="badge" i18nKey="btnCode" text="Código" />
                    </a>
                )
            }
            {
                live && (
                    <a href={live} target="_blank" rel="noopener noreferrer" class="flex-1 btn-base bg-accent text-bg-dark px-3 py-2 hover:brightness-110 shadow-lg shadow-accent/20 gap-2">
                        <img src="/icons/web_icon.svg" width="16" height="16" alt="" class="dark:invert" />
                        <Text as="span" type="badge" extraClass="!text-bg-dark" i18nKey="btnVisit" text="Visitar" />
                    </a>
                )
            }
        </div>
    </div>
</div>
