---
import { Image } from "astro:assets";
import Text from "./text.astro";
import Tooltip from "./Tooltip.astro";
import IconMask from "./IconMask.astro";
const { title, description, image, logo, tech = [], github, live, platform, titleKey, descKey, metrics = [] } = Astro.props;
---

<div class="group card-base hover:-translate-y-1 h-full flex flex-col relative z-10 hover:z-50 transition-all duration-300">
    <div class="w-full relative overflow-hidden bg-accent/5 aspect-video shrink-0 rounded-t-[1.5rem]">
        <Image src={image} alt={title} class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-105" />
    </div>

    <div class="w-full p-4 sm:p-5 flex flex-col flex-1 justify-between gap-4">
        <div class="space-y-4">
            <div class="flex items-center justify-between gap-3 flex-wrap">
                <div class="flex items-center gap-2.5">
                    {logo && <img src={logo} width="28" height="28" class="" alt="" />}
                    <Text as="h3" type="subTitle" extraClass="!text-lg sm:!text-xl tracking-tight" i18nKey={titleKey} text={title} />
                </div>
                {
                    (platform || tech.length > 0) && (
                        <div class="flex items-center gap-2 bg-accent/10 px-2 py-1 rounded-full border border-accent/20">
                            {platform && <img src={platform} width="16" height="16" class="opacity-80" alt="" />}
                            {platform && tech.length > 0 && <div class="w-[1px] h-3 bg-accent/30 mx-1" />}
                            {tech.length > 0 && (
                                <div class="flex gap-2">
                                    {tech.map((t: any) => (
                                        <div class="relative group/tech cursor-help flex items-center">
                                            <img src={t.icon} width="18" height="18" class="transition-opacity duration-300" alt={t.name} />
                                            <Tooltip label={`${t.name}: ${t.role}`} position="top" trigger="group-hover/tech" />
                                        </div>
                                    ))}
                                </div>
                            )}
                        </div>
                    )
                }
            </div>

            <Text type="mini" extraClass="leading-relaxed line-clamp-2 text-white/80" i18nKey={descKey} text={description} />

            {
                metrics.length > 0 && (
                    <div class="flex flex-wrap gap-2 pt-3 border-t border-white/5">
                        {metrics.map((m: string) => (
                            <div class="px-3 py-1.5 rounded-lg bg-bg-card-hover border border-accent/10 hover:border-accent/40 transition-all duration-300">
                                <Text type="badge" extraClass="!text-[10px] sm:!text-[11px] !font-black !text-subtitle tracking-wider" i18nKey={m} text="..." />
                            </div>
                        ))}
                    </div>
                )
            }
        </div>
        <div class="flex items-center gap-2 mt-auto">
            {
                github && (
                    <a href={github} target="_blank" rel="noopener noreferrer" class="flex-1 btn-base bg-bg-card-hover px-3 py-2.5 group/btn text-body transition-colors duration-300 gap-2 font-medium hover:bg-white/10">
                        <IconMask src="/logos/github_logo.svg" extraClass="w-4 h-4" />
                        <Text as="span" type="badge" i18nKey="btnCode" text="Código" />
                    </a>
                )
            }
            {
                live && (
                    <a href={live} target="_blank" rel="noopener noreferrer" class="flex-1 btn-base bg-accent text-bg-dark px-3 py-2.5 hover:brightness-110 shadow-lg shadow-accent/20 gap-2">
                        <img src="/icons/web_icon.svg" width="16" height="16" alt="" class="dark:invert" />
                        <Text as="span" type="badge" extraClass="!text-bg-dark" i18nKey="btnVisit" text="Visitar" />
                    </a>
                )
            }
        </div>
    </div>
</div>
