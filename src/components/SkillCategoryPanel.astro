---
import SkillCard from "./SkillCard.astro";
import Text from "./text.astro";

const { category } = Astro.props;
---

<div class="flex flex-col gap-5 sm:gap-6 p-5 sm:p-7 card-base group">
    <div class="flex items-center gap-4">
        <Text as="h3" type="subTitle" extraClass="!text-xl sm:!text-2xl !font-black !text-title whitespace-nowrap" i18nKey={category.i18nTitle} text={category.title} />
        <div class="h-[2px] w-full bg-[#18cda9] rounded-full opacity-30"></div>
    </div>
    <div class="flex flex-wrap gap-4 sm:gap-6 justify-start">
        {category.skills.map((skill: any) => <SkillCard name={skill.name} icon={skill.icon} i18nExperienceKey={skill.i18nExp} />)}
    </div>
</div>
