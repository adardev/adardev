---
import Pill from "./Pill.astro";
import Text from "./text.astro";
import IconMask from "./IconMask.astro";
const { year, title, subtitle, description, logo, titleKey, subtitleKey, descriptionKey, badge, badgeKey } = Astro.props;
---

<div class="experience-item relative pl-14 sm:pl-24 group pb-10 sm:pb-12">
    <div class="absolute left-[1px] sm:left-[2px] top-[0.8rem] z-20 flex items-center justify-center -translate-x-1/2 pointer-events-none h-8 w-14 sm:w-16">
        <!-- Static indicator dot -->
        <div class="absolute w-3 h-3 sm:w-3.5 sm:h-3.5 bg-accent rounded-full opacity-100 group-[.is-center]:opacity-0 transition-opacity duration-200"></div>

        <!-- Year badge - pop on scroll (unified for mobile and desktop) -->
        <div class="absolute w-14 h-6 sm:w-16 sm:h-7 opacity-0 scale-50 group-[.is-center]:opacity-100 group-[.is-center]:scale-110 bg-accent rounded-full flex items-center justify-center transition-all duration-200 will-change-transform">
            <span class="text-[10px] sm:text-xs font-black text-bg-dark leading-none">{year}</span>
        </div>
    </div>
    <div class="w-full flex flex-col">
        <div class="flex flex-row justify-between gap-3 sm:gap-4 items-start w-full">
            <div class="flex-1 min-w-0 flex flex-col">
                <div class="flex items-center gap-3 flex-wrap">
                    <Text text={title} type="subTitle" color="text-title" i18nKey={titleKey} extraClass="break-words" />
                    {
                        badge && (
                            <div class="px-2 py-0.5 rounded-full border border-[#0b5c4a] bg-[#0d2a24]">
                                <Text text={badge} type="badge" i18nKey={badgeKey} extraClass="!text-accent !text-[10px] uppercase tracking-wider !font-black" />
                            </div>
                        )
                    }
                </div>
                <Text text={subtitle} type="text" extraClass="!text-subtitle !text-base sm:!text-lg pl-0" i18nKey={subtitleKey} />
            </div>
            {
                logo && (
                    <div class="shrink-0 flex items-center justify-end h-12 sm:h-16 text-body">
                        <IconMask src={logo} extraClass="w-12 h-12" />
                    </div>
                )
            }
        </div>
        <Text text={description} type="mini" extraClass="mt-2 leading-relaxed max-w-2xl" i18nKey={descriptionKey} />
    </div>
</div>
