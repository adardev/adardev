---
import Text from "./text.astro";
const { label, i18nKey, position = "top", techName } = Astro.props;
const positionStyles = {
    top: "bottom-full mb-2 left-1/2 -translate-x-1/2",
    bottom: "top-full mt-2 left-1/2 -translate-x-1/2",
};
const arrowStyles = {
    top: "-bottom-1 left-1/2 -translate-x-1/2 border-b border-r",
    bottom: "-top-1 left-1/2 -translate-x-1/2 border-t border-l",
};
---

<div class={`tooltip-float ${(positionStyles as any)[position]} px-3 py-1.5 min-w-max bg-bg-dark/95 backdrop-blur-md rounded-lg shadow-2xl opacity-0 translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 border border-accent/40 z-[150] transition-all duration-300 pointer-events-none flex flex-col items-center`}>
    {techName && <span class="text-[9px] text-white/50 font-bold tracking-wider mb-0.5">{techName}</span>}
    <Text as="span" type="tooltip" i18nKey={i18nKey} text={label} extraClass="text-[11px] font-medium text-accent" />
    <div class={`absolute w-1.5 h-1.5 bg-bg-dark/95 border-accent/40 transform rotate-45 ${(arrowStyles as any)[position]} group-hover:opacity-100`}></div>
</div>
