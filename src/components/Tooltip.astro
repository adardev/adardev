---
import Text from "./text.astro";
const { label, i18nKey, position = "top", trigger = "group-hover" } = Astro.props;

const positionStyles: Record<string, string> = {
    top: "bottom-full mb-2 left-1/2 -translate-x-1/2",
    bottom: "top-full mt-2 left-1/2 -translate-x-1/2",
};
const arrowStyles: Record<string, string> = {
    top: "-bottom-1 left-1/2 -translate-x-1/2 border-b border-r",
    bottom: "-top-1 left-1/2 -translate-x-1/2 border-t border-l",
};
---

<div class={`tooltip-float ${positionStyles[position]} px-3 py-1.5 min-w-max bg-bg-card rounded-lg shadow-xl opacity-0 translate-y-2 ${trigger}:opacity-100 ${trigger}:translate-y-0 border border-accent/20 z-[110] transition-all duration-200`}>
    <Text as="span" type="tooltip" i18nKey={i18nKey} text={label} />
    <div class={`absolute w-2 h-2 bg-bg-card border-accent/20 transform rotate-45 ${arrowStyles[position]}`}></div>
</div>
